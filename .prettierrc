# Prettier configuration
semi: true
singleQuote: true
trailingComma: es5
printWidth: 80
arrowParens: always
endOfLine: lf

# ESLint overrides for pre-commit
overrides:
  - files: ["*.ts", "*.tsx"]
    rules:
      "@typescript-eslint/no-unused-vars": "error"
      "@typescript-eslint/explicit-module-boundary-types": "off"

["**/*.js"]
indent_style: space
indent_size: 2
max_line_length: 100

["**/*.ts"]
indent_style: space
indent_size: 2
max_line_length: 100

["**/*.json"]
indent_style: space
indent_size: 2